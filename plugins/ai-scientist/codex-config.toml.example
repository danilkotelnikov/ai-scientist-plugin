# Append the contents of this file to ~/.codex/config.toml to enable the
# ai-scientist plugin in Codex.
#
# On Linux/macOS, replace ${env:USERPROFILE} with ${env:HOME}.
#
# ============================================================================
# IMPORTANT -- READ BEFORE APPENDING
# ============================================================================
#
# 1. [features] block:
#    This file deliberately does NOT contain a [features] block. Most Codex
#    installs already have one, and TOML forbids two sections with the same
#    name. Confirm your existing [features] table in ~/.codex/config.toml
#    contains:
#
#        multi_agent = true
#
#    (it usually already does on recent Codex versions). If you have no
#    [features] section at all, add one anywhere in the file with that
#    single key. multi_agent unlocks spawn_agent / wait / close_agent,
#    which the orchestrator needs.
#
# 2. [mcp_servers.X] duplicates:
#    This file registers 9 MCP servers under [mcp_servers.ai-scientist],
#    [mcp_servers.mempalace], [mcp_servers.openalex],
#    [mcp_servers.semanticscholar], [mcp_servers.arxiv],
#    [mcp_servers.biorxiv], [mcp_servers.pubmed], [mcp_servers.annas-mcp],
#    [mcp_servers.fetcher].
#
#    If your existing config.toml ALREADY registers any of these names
#    (e.g. from a previous ai-scientist install or another plugin that
#    happens to use the same name), `codex restart` will fail with
#    "duplicate key" because TOML forbids the same table twice.
#
#    Before appending, grep your config:
#
#        grep -E '^\[mcp_servers\.(ai-scientist|mempalace|openalex|semanticscholar|arxiv|biorxiv|pubmed|annas-mcp|fetcher)\]' ~/.codex/config.toml
#
#    For each match, EITHER delete the existing block (if it's stale) OR
#    skip the matching block from this file when copying. Do not paste a
#    second copy on top.

# ============================================================================
# AI-Scientist core MCP -- knowledge store, codebase analyzer, meta-analysis
# ============================================================================
[mcp_servers.ai-scientist]
command = "python"
args = [
  "${env:USERPROFILE}/.codex/ai-scientist-plugin/plugins/ai-scientist/mcp/server.py",
  "--mode",
  "stdio",
]
env = { AI_SCIENTIST_HOME = "${env:USERPROFILE}/.ai-scientist", PYTHONPATH = "${env:USERPROFILE}/.codex/ai-scientist-plugin/plugins/ai-scientist/mcp/lib" }

# ============================================================================
# MemPalace — per-project memory DB with auto-save before context compaction
# ============================================================================
[mcp_servers.mempalace]
command = "mempalace-mcp"
env = { MEMPALACE_ROOT = "${env:USERPROFILE}/.ai-scientist/palace" }

# ============================================================================
# Literature DB MCPs — all 6 enabled for Codex
# ============================================================================

# OpenAlex (drAbreu/alex-mcp v4.1.0) — 240M+ scholarly works
[mcp_servers.openalex]
command = "uvx"
args = [
  "--from",
  "git+https://github.com/drAbreu/alex-mcp.git@4.1.0",
  "alex-mcp",
]
env = { OPENALEX_MAILTO = "${env:OPENALEX_EMAIL}", OPENALEX_RATE_PER_SEC = "10" }

# Semantic Scholar (JackKuo666/semanticscholar-MCP-Server, cloned at install time)
[mcp_servers.semanticscholar]
command = "python"
args = [
  "${env:USERPROFILE}/.ai-scientist/external/semanticscholar-MCP-Server/semantic_scholar_server.py",
]
env = { SEMANTIC_SCHOLAR_API_KEY = "${env:SEMANTIC_SCHOLAR_KEY}" }

# arXiv — preprint search via arxiv-mcp-server (uvx-installed)
[mcp_servers.arxiv]
command = "uvx"
args = ["arxiv-mcp-server"]

# bioRxiv / medRxiv — JackKuo666/bioRxiv-MCP-Server (cloned at install time)
[mcp_servers.biorxiv]
command = "python"
args = [
  "${env:USERPROFILE}/.ai-scientist/external/bioRxiv-MCP-Server/biorxiv_server.py",
]

# PubMed — biomedical literature
[mcp_servers.pubmed]
command = "npx"
args = ["-y", "pubmed-mcp"]

# Anna's Archive — full-text article access (npx-installed)
[mcp_servers.annas-mcp]
command = "npx"
args = ["-y", "annas-mcp", "mcp"]
env = { ANNAS_BASE_URL = "${env:ANNAS_BASE_URL}", ANNAS_DOWNLOAD_PATH = "${env:ANNAS_DOWNLOAD_PATH}", ANNAS_SECRET_KEY = "${env:ANNAS_SECRET_KEY}" }

# Consensus — AI-curated academic search.
# Consensus does not currently ship an open MCP server. The literature-searcher
# falls back to https://consensus.app/papers/?q=<query> via the fetcher MCP.
# If a Consensus MCP becomes available, replace the fetcher fallback below.
[mcp_servers.fetcher]
command = "npx"
args = ["-y", "fetcher-mcp"]
