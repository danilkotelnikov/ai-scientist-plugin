{
  "name": "vedix",
  "version": "3.0.0",
  "description": "End-to-end agentic research workbench. Turns a topic into a venue-ready manuscript across Claude Code, Codex CLI, and Gemini CLI. 17 specialized subagents, Source-Grounded Claim Architecture (SGCA), per-project MemPalace memory, 9 pre-configured MCP servers, 23 publisher templates, 7 first-class languages.",
  "contextFileName": "GEMINI.md",
  "settings": [
    {"name": "OpenAlex email", "description": "Your contact email for the OpenAlex polite pool (required since 2026-02-13)", "envVar": "OPENALEX_EMAIL"},
    {"name": "Semantic Scholar API key", "description": "Optional — unlocks /search endpoint", "envVar": "SEMANTIC_SCHOLAR_KEY", "sensitive": true},
    {"name": "Anna's Archive base URL", "description": "Mirror URL for Anna's Archive", "envVar": "ANNAS_BASE_URL"},
    {"name": "Anna's Archive download path", "description": "Local path for full-text PDF downloads", "envVar": "ANNAS_DOWNLOAD_PATH"},
    {"name": "Anna's Archive secret key", "description": "Member-tier access key", "envVar": "ANNAS_SECRET_KEY", "sensitive": true}
  ],
  "mcpServers": {
    "vedix": {
      "command": "python",
      "args": [
        "${extensionPath}/plugins/vedix/mcp/server.py",
        "--mode",
        "stdio"
      ],
      "env": {
        "PYTHONPATH": "${extensionPath}/plugins/vedix/mcp/lib"
      },
      "cwd": "${extensionPath}/plugins/vedix"
    },
    "mempalace": {
      "command": "mempalace-mcp"
    },
    "openalex": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/drAbreu/alex-mcp.git@4.1.0",
        "alex-mcp"
      ],
      "env": {
        "OPENALEX_RATE_PER_SEC": "10"
      }
    },
    "semanticscholar": {
      "command": "python",
      "args": [
        "${extensionPath}/../../../.vedix/external/semanticscholar-MCP-Server/semantic_scholar_server.py"
      ]
    },
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server"]
    },
    "biorxiv": {
      "command": "python",
      "args": [
        "${extensionPath}/../../../.vedix/external/bioRxiv-MCP-Server/biorxiv_server.py"
      ]
    },
    "pubmed": {
      "command": "npx",
      "args": ["-y", "pubmed-mcp"]
    },
    "annas-mcp": {
      "command": "npx",
      "args": ["-y", "annas-mcp", "mcp"]
    },
    "scihub": {
      "command": "python",
      "args": [
        "${extensionPath}/../../../.vedix/external/Sci-Hub-MCP-Server/sci_hub_server.py"
      ]
    },
    "fetcher": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp"]
    }
  }
}
